{
  "name": "struct-parser-vscode",
  "displayName": "Struct Parser Viewer",
  "description": "Parse and visualize C-style struct data from hex values",
  "version": "1.0.0",
  "publisher": "neewe",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Debuggers",
    "Data Science"
  ],
  "keywords": [
    "struct",
    "parser",
    "hex",
    "binary",
    "embedded",
    "register"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeeWe/struct-parser-vscode.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "structParser.openViewer",
        "title": "Open Struct Parser Viewer",
        "category": "Struct Parser",
        "icon": "$(preview)"
      },
      {
        "command": "structParser.openViewerWithStruct",
        "title": "Open with Struct",
        "category": "Struct Parser"
      },
      {
        "command": "structParser.parseFromHex",
        "title": "Parse Hex Value",
        "category": "Struct Parser"
      },
      {
        "command": "structParser.importJson",
        "title": "Import JSON File",
        "category": "Struct Parser",
        "icon": "$(file-add)"
      },
      {
        "command": "structParser.refresh",
        "title": "Refresh",
        "category": "Struct Parser",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "structParser.parseFromHex",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste@5"
        }
      ],
      "view/title": [
        {
          "command": "structParser.importJson",
          "when": "view == structExplorer",
          "group": "navigation"
        },
        {
          "command": "structParser.refresh",
          "when": "view == structExplorer",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "structParser",
          "title": "Struct Parser",
          "icon": "images/struct-parser-icon.svg"
        }
      ]
    },
    "views": {
      "structParser": [
        {
          "id": "structExplorer",
          "name": "Struct Explorer",
          "icon": "$(symbol-structure)",
          "contextualTitle": "Struct Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Struct Parser",
      "properties": {
        "structParser.jsonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the struct parser JSON output file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
